datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Order {
  id            String   @id @default(uuid())
  email         String
  name          String
  phone         String
  product       String   @default("dadi-sutra")
  orderId       String   @unique // Razorpay Order ID or Stripe Checkout Session ID
  paymentId     String?  // Razorpay Payment ID or Stripe Payment Intent ID
  amount        Int      // in paise (INR) or cents
  status        String   // PENDING, PAID, FAILED
  downloadCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Lead {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
